# Força todos os arquivos de texto a usar LF
* text=auto eol=lf

# Arquivos YAML sempre com LF
*.yml text eol=lf
*.yaml text eol=lf

# Arquivos JSON sempre com LF
*.json text eol=lf

# Arquivos shell sempre com LF
*.sh text eol=lf

# Arquivos binários não devem ser alterados
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary